# ── 포트 (단일 소스) ──────────────────────────────────────
# API_PORT / WEB_PORT 두 값만 바꾸면 아래 URL 들의 기본값이 모두 따라갑니다.
API_PORT=9010
WEB_PORT=9011
# PORT 는 API_PORT 의 하위호환 alias (설정 시 API_PORT 가 우선)
PORT=9010

# 개발: API 서버 직접 지정 / 운영(Apache same-origin): 빈 값 또는 미설정
NUXT_PUBLIC_API_BASE=http://localhost:9010
API_INTERNAL_BASE=http://localhost:9010

# 업로드(미디어) 저장 디렉터리
UPLOAD_DIR=/backup/InsureDesign

# 사이트 주소 (인증 링크 생성에 사용)
SITE_URL=http://localhost:9011

# 사이트 이름 (DB 설정 siteName 이 비어있을 때의 폴백)
SITE_NAME=InsureDesign
# 사이트 기본 설명 (SEO meta description 폴백 — 글에 요약이 없을 때 사용)
SITE_DESCRIPTION=

# 로그인 우회(dev 전용). true 면 로그인 없이 super 접근 — 로그아웃도 무력화됨. 운영은 반드시 false
AUTH_BYPASS=false

# ── mongodb ──────────────────────────────────────────────
MONGODB_ADDR=
MONGO_USERNAME=
MONGO_PWD=
MONGO_DBNAME=InsureDesign

# ── kakao login ──────────────────────────────────────────
# 콜백은 API 서버(9010) + /api 경로. 콘솔에 동일 URL 등록 필수
KAKAO_CLIENT_ID=
# 클라이언트 시크릿: 콘솔에서 '사용함'이면 필수, '사용 안 함'이면 이 줄 삭제
KAKAO_CLIENT_SECRET=
KAKAO_CALLBACK_URL=http://localhost:9010/api/auth/kakao/callback

# ── naver login ──────────────────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=http://localhost:9010/api/auth/naver/callback

# 세션 서명 비밀키 (충분히 긴 랜덤 문자열)
NUXT_SESSION_PASSWORD=
NUXT_SITE_URL=http://localhost:9011

# ── iDrive e2 (S3 호환 스토리지) ──────────────────────────
CLOUD_BUCKET=
CLOUD_ENDPOINT=https://s3.ap-northeast-1.idrivee2.com
CLOUD_REGION=ap-northeast-1
CLOUD_ACCESS_KEY_ID=
CLOUD_SECRET_ACCESS_KEY=
CLOUD_PUBLIC_URL=

# 2FA 복구 코드
Google_Authenticator_recovery_code=

# ── SMTP 이메일 ──────────────────────────────────────────
EMAIL_HOST=smtp.worksmobile.com
EMAIL_PORT=465
EMAIL_USER=
# 네이버 계정 → 보안 → 2단계 인증 → 앱 비밀번호 관리 → 앱 비밀번호 발급
EMAIL_PASS=
EMAIL_FROM=

# ── LLM (보험분석) ───────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
